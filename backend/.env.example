# ============================================
# INSTRUÇÕES DE CONFIGURAÇÃO
# ============================================
# 
# Copie este arquivo para .env e preencha as credenciais abaixo
# 
# PASSO 1: Criar conta Supabase (https://supabase.com)
# PASSO 2: Criar app Meta Developers (https://developers.facebook.com/apps)
# PASSO 3: Preencher as variáveis abaixo
# PASSO 4: Rodar: npm install && npx prisma generate && npx prisma migrate dev
# 
# ============================================

# Environment
NODE_ENV=development
PORT=3001

# ============================================
# BANCO DE DADOS (SUPABASE)
# ============================================
# 1. Acesse: https://supabase.com/
# 2. Crie um projeto
# 3. Vá em Settings → Database → Connection String → URI
# 4. Cole aqui (substitua [YOUR-PASSWORD] pela senha que você criou)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD_HERE@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# ============================================
# META ADS (FACEBOOK FOR DEVELOPERS)
# ============================================
# 1. Acesse: https://developers.facebook.com/apps/
# 2. Crie um app (tipo: Business)
# 3. Vá em Settings → Basic
# 4. Copie App ID e App Secret
# 5. Adicione produtos: Facebook Login + Marketing API
# 6. Configure OAuth Redirect: http://localhost:3001/api/auth/meta/callback
META_APP_ID=YOUR_META_APP_ID_HERE
META_APP_SECRET=YOUR_META_APP_SECRET_HERE
META_REDIRECT_URI=http://localhost:3001/api/auth/meta/callback

# ============================================
# CHAVES DE SEGURANÇA
# ============================================
# Gere chaves únicas com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=YOUR_SESSION_SECRET_HERE
ENCRYPTION_KEY=YOUR_ENCRYPTION_KEY_HERE

# ============================================
# CONFIGURAÇÕES GERAIS
# ============================================
FRONTEND_URL=http://localhost:5173

# Cron Job (Sincronização Automática)
ENABLE_CRON=true
SYNC_SCHEDULE="0 6 * * *"
